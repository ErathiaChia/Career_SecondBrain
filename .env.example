# Copy this file to .env and fill in the private values locally.
# ERA_VAULT_DB_* is read by era_indexer, era_mcp, and era_auditor (the auditor
# auto-builds its database URL from these vars when AUDITOR_DATABASE_URL is unset).

# Hugging Face token used for one-time model bootstrap.
HF_TOKEN="hf_your_token_here"

# Synology PostgreSQL connection details.
ERA_VAULT_DB_HOST="192.168.50.75"
ERA_VAULT_DB_PORT="15432"
ERA_VAULT_DB_NAME="era_vault"
ERA_VAULT_DB_USER="era"
ERA_VAULT_DB_PASSWORD="your_database_password_here"

# OpenAI / ChatGPT API used by the standalone AI Auditor Agent.
OPENAI_API_KEY="sk-your_openai_key_here"
OPENAI_MODEL="gpt-4.1-mini"

# --- era_mcp V3 retrieval relevance (all optional; sensible defaults shown) ---
# Query embedding instruction (qwen3-embedding is instruction-tuned). Set to 0
# if you revert EMBEDDING_MODEL to a non-instruction model like bge-m3.
QUERY_INSTRUCTION_ENABLED="1"
# Also match the lexical channel on file_name/folder/path (helps acronyms, names).
FILENAME_SEARCH_ENABLED="1"
LEXICAL_PATH_WEIGHT="0.5"
# Retrieve for the rewriter's sub-queries too and fuse the pools.
MULTI_QUERY_ENABLED="1"
# Size retrieval breadth to question complexity (simple/moderate/complex).
ADAPTIVE_TOPK_ENABLED="1"
TOPK_SIMPLE="8"
TOPK_MODERATE="20"
TOPK_COMPLEX="40"
# Group /ask context by document (coherent docs vs scattered passages).
DOC_FIRST_ASSEMBLY_ENABLED="1"
DOC_FIRST_MAX_DOCS="8"
DOC_FIRST_MAX_PARENTS_PER_DOC="3"
# Cross-encoder reranker (Fix 4): default llm_score; switch to a real
# cross-encoder by running era_mcp/tools/run_reranker.sh on the Mac and setting:
# RERANK_KIND="infinity"
# RERANK_BASE_URL="http://<mac-lan-ip>:7997"
# RERANK_MODEL="BAAI/bge-reranker-v2-m3"
