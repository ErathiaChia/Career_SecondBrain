# Copy this file to .env and fill in the private values locally.
# ERA_VAULT_DB_* is read by era_indexer, era_mcp, and era_auditor (the auditor
# auto-builds its database URL from these vars when AUDITOR_DATABASE_URL is unset).

# Hugging Face token used for one-time model bootstrap.
HF_TOKEN="hf_your_token_here"

# Synology PostgreSQL connection details.
ERA_VAULT_DB_HOST="192.168.50.75"
ERA_VAULT_DB_PORT="15432"
ERA_VAULT_DB_NAME="era_vault"
ERA_VAULT_DB_USER="era"
ERA_VAULT_DB_PASSWORD="your_database_password_here"

# OpenAI / ChatGPT API used by the standalone AI Auditor Agent.
OPENAI_API_KEY="sk-your_openai_key_here"
OPENAI_MODEL="gpt-4.1-mini"
